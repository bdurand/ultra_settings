<% unless color_scheme == :dark %>
  :root {
    --font-ui: system-ui, -apple-system, sans-serif;
    --font-mono: "SF Mono", Menlo, Consolas, monospace;
    --bg-page: #f4f5f7;
    --text-primary: #111827;
    --text-secondary: #4b5563;
    --text-tertiary: #9ca3af;
    --accent: #0d9488;
    --border-light: #e2e5ea;
  }
<% end %>

